+        void scheduleRenderChart();
+      }
+    });
+    resizeObserver.observe(rootRef.value);
+  }
+
+  void scheduleRenderChart();
+});
+
+watch(option, () => {
+  void scheduleRenderChart();
+}, { deep: true, flush: 'post' });
