+  chart ??= echarts.init(chartRef.value);
+  chart.setOption(option.value, true);
+  chart.resize();
+};
+
+const scheduleRenderChart = async () => {
+  await nextTick();
+  renderChart();
+};
+
+onMounted(() => {
