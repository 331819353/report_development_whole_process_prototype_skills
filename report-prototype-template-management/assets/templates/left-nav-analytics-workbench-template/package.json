{
  "name": "haier-left-nav-analytics-workbench",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-with-mock-api.mjs",
    "dev:auto": "node scripts/dev-with-mock-api.mjs",
    "dev:vite": "vite --mode development --host 0.0.0.0",
    "dev:mock": "node scripts/dev-with-mock-api.mjs",
    "mock:api": "node scripts/mock-api-server.mjs",
    "validate:dashboard": "node scripts/validate-dashboard-contract.mjs",
    "visual:geometry": "node scripts/visual-geometry-audit.mjs",
    "ledger:code": "node scripts/update-code-ledger.mjs",
    "ledger:init": "node scripts/init-code-ledgers.mjs --write",
    "ledger:check": "node scripts/init-code-ledgers.mjs",
    "build": "npm run build:prod",
    "build:preview": "npm run validate:dashboard && vue-tsc --noEmit && vite build --mode preview",
    "build:test": "npm run validate:dashboard && vue-tsc --noEmit && vite build --mode test",
    "build:prod": "npm run validate:dashboard && vue-tsc --noEmit && vite build --mode production",
    "preview": "vite preview --host 0.0.0.0",
    "preview:auto": "node scripts/start-available-port.mjs --mode preview"
  },
  "dependencies": {
    "@antv/s2": "^2.7.2",
    "@lucide/vue": "^1.16.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "axios": "^1.17.0",
    "dayjs": "^1.11.21",
    "echarts": "^6.1.0",
    "element-plus": "^2.14.2",
    "pinia": "^3.0.4",
    "sass": "^1.100.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.1.10"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "playwright": "^1.61.0"
  }
}
